{% comment %}
  ============================================================
  MEUSE — HERO BANNER SECTION (FIXED)
  File: sections/meuse-hero-banner.liquid

  Layout (matches Figma exactly):
    Line 1:  "Visit our"           ← serif, light
    Line 2:  "amazon Store"        ← amazon bold + Store serif, SAME LINE
             [Amazon smile arrow beneath]
    Button:  SHOP NOW              ← olive bg, white border, NO radius

  Fixes applied:
    - Removed broken block definitions from schema (section has no blocks)
    - Fixed Amazon smile SVG to match actual Amazon arrow (not generic curve)
    - Fixed button to have white border (matches Figma: bordered button style)
    - Fixed btn_new_tab default to false
    - Cleaned up all settings to be self-contained (no external CSS dependencies)
  ============================================================
{% endcomment %}

{%- style -%}

  /* ── Section wrapper ─────────────────────────────── */
  #meuse-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_height }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Background image ────────────────────────────── */
  #meuse-hero-{{ section.id }} .mh__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #meuse-hero-{{ section.id }} .mh__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── Optional overlay ────────────────────────────── */
  #meuse-hero-{{ section.id }} .mh__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
    pointer-events: none;
  }

  /* ── Content block ───────────────────────────────── */
  #meuse-hero-{{ section.id }} .mh__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px;
  }

  /* ── Line 1: "Visit our" ─────────────────────────── */
  #meuse-hero-{{ section.id }} .mh__line-top {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.2rem, 3.8vw, 3.8rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: 0.02em;
    margin: 0 0 0.1em;
  }

  /* ── Line 2: "amazon Store" — SAME LINE ─────────── */
  #meuse-hero-{{ section.id }} .mh__line-brand-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.2em;
    line-height: 1;
    margin: 0;
  }

  /* "amazon" — bold sans */
  #meuse-hero-{{ section.id }} .mh__amazon-word {
    font-family: 'Helvetica Neue', 'Arial Black', Arial, sans-serif;
    font-size: clamp(3rem, 5.2vw, 5.2rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: lowercase;
  }

  /* "Store" — serif, same line */
  #meuse-hero-{{ section.id }} .mh__store-word {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.2rem, 3.8vw, 3.8rem);
    font-weight: 400;
    color: #ffffff;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* ── Amazon smile arrow — beneath "amazon Store" ─── */
  /*    Sized to sit under the "amazon" word width      */
  #meuse-hero-{{ section.id }} .mh__arrow {
    display: block;
    width: clamp(80px, 10vw, 130px);
    height: auto;
    /* Align it left-of-centre to sit under "amazon" text, not "Store" */
    margin: 0.15em 0 1.8rem;
    align-self: center;
  }

  /* ── Button — olive bg, white border, NO radius ──── */
  #meuse-hero-{{ section.id }} .mh__btn {
    display: inline-block;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_color }};
    border: 1px solid {{ section.settings.btn_border_color }};
    border-radius: 0;
    font-family: 'Jost', 'Gill Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 48px;
    min-width: 180px;
    cursor: pointer;
    transition: background-color 0.25s ease, opacity 0.25s ease;
  }

  #meuse-hero-{{ section.id }} .mh__btn:hover {
    opacity: 0.85;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media screen and (max-width: 989px) {
    #meuse-hero-{{ section.id }} {
      min-height: {{ section.settings.section_height | times: 0.75 | round }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #meuse-hero-{{ section.id }} {
      min-height: {{ section.settings.section_height | times: 0.60 | round }}px;
    }
    #meuse-hero-{{ section.id }} .mh__btn {
      padding: 13px 32px;
      font-size: 10px;
      min-width: 140px;
    }
    #meuse-hero-{{ section.id }} .mh__line-brand-row {
      flex-wrap: wrap;
    }
  }

{%- endstyle -%}

{{- 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Jost:wght@400;500&display=swap' | stylesheet_tag -}}

<section id="meuse-hero-{{ section.id }}" class="meuse-hero">

  <!-- ① Background image -->
  <div class="mh__bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.bg_image | image_url: width: 750  }} 750w,
          {{ section.settings.bg_image | image_url: width: 1100 }} 1100w,
          {{ section.settings.bg_image | image_url: width: 1500 }} 1500w,
          {{ section.settings.bg_image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.bg_image.alt | escape | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="800"
      >
    {%- else -%}
      <div style="width:100%;height:100%;min-height:inherit;background:linear-gradient(135deg,#2e3d28,#4a5e3a);"></div>
    {%- endif -%}
  </div>

  <!-- ② Overlay -->
  <div class="mh__overlay"></div>

  <!-- ③ Content -->
  <div class="mh__content">

    <!-- Line 1: "Visit our" -->
    <span class="mh__line-top">
      {{- section.settings.line_top -}}
    </span>

    <!-- Line 2: "amazon Store" on SAME LINE -->
    <div class="mh__line-brand-row">
      <span class="mh__amazon-word">{{- section.settings.line_brand -}}</span>
      <span class="mh__store-word">{{- section.settings.line_store -}}</span>
    </div>

    <!--
      Amazon smile arrow — matches the real Amazon arrow shape:
      a flat curve that starts low-left, rises to centre, then sweeps
      down-right with a pointed tail (like the amazon.com logo arrow).
      Colour is white. Sized to sit under the "amazon" word.
    -->
    <svg
      class="mh__arrow"
      viewBox="0 0 120 30"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!--
        Amazon-style smile:
        Starts at left (~x=4), curves up and across,
        ends with a downward arrowhead tip on the right (~x=116).
        The path intentionally mirrors the amazon logo smile arc.
      -->
      <path
        d="M4 10 Q30 26 60 22 Q90 18 108 8"
        stroke="#ffffff"
        stroke-width="3"
        stroke-linecap="round"
        fill="none"
      />
      <!-- Arrowhead pointing down-right, matching Amazon logo tip -->
      <path
        d="M100 4 L108 8 L104 16"
        stroke="#ffffff"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
    </svg>

    <!-- CTA Button -->
    {%- if section.settings.btn_text != blank -%}
      <a
        href="{{ section.settings.btn_link | default: routes.collections_url }}"
        class="mh__btn"
        {%- if section.settings.btn_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
      >
        {{- section.settings.btn_text -}}
      </a>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Meuse Hero Banner",
  "tag": "div",
  "class": "meuse-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "📷 Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height (px)",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 650
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness (%)",
      "info": "0 = no overlay. Increase if text is hard to read over the image.",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 10
    },
    {
      "type": "header",
      "content": "✏️ Heading Text"
    },
    {
      "type": "text",
      "id": "line_top",
      "label": "Line 1 — top text",
      "default": "Visit our",
      "info": "Displays in light serif font above the brand name"
    },
    {
      "type": "text",
      "id": "line_brand",
      "label": "Line 2 — brand name (bold)",
      "default": "amazon",
      "info": "Displays bold, same line as the word after it"
    },
    {
      "type": "text",
      "id": "line_store",
      "label": "Line 2 — word after brand",
      "default": "Store",
      "info": "Sits on the same line as the brand name above"
    },
    {
      "type": "header",
      "content": "🔘 Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "btn_new_tab",
      "label": "Open link in new tab",
      "default": false,
      "info": "Turn on if linking to an external site like Amazon"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background color",
      "default": "#3a4a2f"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button border color",
      "default": "#ffffff",
      "info": "Visible border around the button — matches Figma design"
    }
  ],
  "presets": [
    {
      "name": "Meuse Hero Banner",
      "category": "Hero"
    }
  ]
}
{% endschema %}
