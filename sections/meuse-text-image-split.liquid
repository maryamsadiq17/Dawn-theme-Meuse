{% comment %}
  ============================================================
  MEUSE — TEXT & IMAGE SPLIT SECTION (PIXEL PERFECT FIGMA)
  File: sections/meuse-text-image-split.liquid
  ============================================================
{% endcomment %}

{%- style -%}
  /* ── Main Section Wrapper ───────────────────────────── */
  #mtis-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_height_desktop }}px;
    background-color: {{ section.settings.section_bg }};
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* ── 50/50 Split Grid (Edge-to-Edge) ─────────────────── */
  #mtis-{{ section.id }} .mtis__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    min-height: {{ section.settings.section_height_desktop }}px;
    position: relative;
    z-index: 2; /* Sits above the background vectors */
  }

  /* ── Left Side: Image ────────────────────────────────── */
  #mtis-{{ section.id }} .mtis__image-column {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  #mtis-{{ section.id }} .mtis__image-column img,
  #mtis-{{ section.id }} .mtis__image-column .mtis__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #mtis-{{ section.id }} .mtis__placeholder {
    background-color: #e2e2e2;
  }

  /* ── Right Side: Text Card ───────────────────────────── */
  #mtis-{{ section.id }} .mtis__text-column {
    background-color: {{ section.settings.block_bg }};
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 5% 10% 5% 12%; /* Generous inner spacing matching Figma */
    box-sizing: border-box;
  }

  #mtis-{{ section.id }} .mtis__content {
    max-width: 540px; /* Prevents text from stretching too wide */
    width: 100%;
  }

  /* ── Typography ──────────────────────────────────────── */
  #mtis-{{ section.id }} .mtis__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    line-height: 1.25;
    color: {{ section.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 28px 0;
  }

  #mtis-{{ section.id }} .mtis__text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: {{ section.settings.text_size }}px;
    font-weight: 400;
    line-height: 1.65;
    color: {{ section.settings.text_color }};
    letter-spacing: 0.01em;
    margin: 0;
  }

  #mtis-{{ section.id }} .mtis__text p {
    margin: 0 0 18px 0;
  }
  #mtis-{{ section.id }} .mtis__text p:last-child {
    margin: 0;
  }

  /* ── Vector Topography Elements ───────────────────────── */
  #mtis-{{ section.id }} .mtis__vector {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.vector_opacity | divided_by: 100.0 }};
  }

  /* Top Right Vector Box */
  #mtis-{{ section.id }} .mtis__vector--top-right {
    top: 0;
    right: 0;
    width: clamp(250px, 22vw, 420px);
    transform: translate(5%, -5%); /* Shifts slightly out like the design */
  }

  /* Bottom Left Vector Box */
  #mtis-{{ section.id }} .mtis__vector--bottom-left {
    bottom: 0;
    left: 0;
    width: clamp(220px, 18vw, 340px);
    transform: translate(-5%, 5%);
  }

  #mtis-{{ section.id }} .mtis__vector svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Responsive Mobile/Tablet Breakdowns ──────────────── */
  @media screen and (max-width: 989px) {
    #mtis-{{ section.id }} {
      min-height: auto;
      display: block;
    }

    #mtis-{{ section.id }} .mtis__grid {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    #mtis-{{ section.id }} .mtis__image-column {
      height: 450px; /* Fixed proportional height for mobile viewports */
    }

    #mtis-{{ section.id }} .mtis__text-column {
      padding: 60px 24px;
      justify-content: center;
    }

    #mtis-{{ section.id }} .mtis__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      margin-bottom: 20px;
    }

    #mtis-{{ section.id }} .mtis__text {
      font-size: {{ section.settings.text_size_mobile }}px;
    }

    /* scale down background vectors safely for mobile screen spaces */
    #mtis-{{ section.id }} .mtis__vector--top-right {
      width: 180px;
    }
    #mtis-{{ section.id }} .mtis__vector--bottom-left {
      width: 140px;
    }
  }
{%- endstyle -%}

{{- 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&display=swap' | stylesheet_tag -}}

<div id="mtis-{{ section.id }}" class="meuse-text-image-split">
  
  <div class="mtis__vector mtis__vector--top-right">
    <svg viewBox="0 0 357 282" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M72.5 0C110.5 83.5 240.5 45.5 357 101M0 45C86.5 111.5 158.5 20.5 357 149M0 115C118.5 186.5 143.5 69.5 357 197.5M0 191.5C149.5 261 179.5 119.5 357 241M41 281.5C193.5 329.5 233.5 178 357 281.5" stroke="{{ section.settings.vector_color }}" stroke-width="0.6"/>
    </svg>
  </div>

  <div class="mtis__vector mtis__vector--bottom-left">
    <svg viewBox="0 0 294 227" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 0C46.5 36.5 83 91.5 59.5 137.5C36 183.5 -17.5 192.5 0 227M0 49C78.5 85.5 125.5 127 109 167C92.5 207 41.5 208.5 54 227M0 102C106 136.5 162.5 160 152 192C141.5 224 99.5 219.5 108.5 227M0 151.5C124 179.5 190.5 191 189 211C187.5 231 154.5 224.5 160.5 227M0 199.5C136 218 214 221.5 217.5 225C221 228.5 199.5 226.5 204.5 227" stroke="{{ section.settings.vector_color }}" stroke-width="0.6"/>
    </svg>
  </div>

  <div class="mtis__grid">
    
    <div class="mtis__image-column">
      {%- if section.settings.image != blank -%}
        {%- capture sizes -%}(min-width: 990px) 50vw, 100vw{%- endcapture -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag:
          loading: 'lazy',
          sizes: sizes,
          widths: '400, 600, 800, 1000, 1200, 1400, 1600',
          alt: section.settings.heading
        }}
      {%- else -%}
        <div class="mtis__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
      {%- endif -%}
    </div>

    <div class="mtis__text-column">
      <div class="mtis__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="mtis__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="mtis__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Meuse Text-Image Split",
  "tag": "section",
  "class": "meuse-split-section",
  "settings": [
    {
      "type": "header",
      "content": "Media Asset"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "header",
      "content": "Section Configuration"
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "label": "Desktop Height (px)",
      "min": 500,
      "max": 1200,
      "step": 4,
      "default": 952
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Outer Canvas Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "block_bg",
      "label": "Text Block Background Box",
      "default": "#d2d7cb"
    },
    {
      "type": "header",
      "content": "Vector Lines Artwork"
    },
    {
      "type": "color",
      "id": "vector_color",
      "label": "Vector Stroke Color",
      "default": "#2a2a2a"
    },
    {
      "type": "range",
      "id": "vector_opacity",
      "label": "Vector Opacity (%)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "header",
      "content": "Typography Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#2a2a2a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#2a2a2a"
    },
    {
      "type": "header",
      "content": "Typography Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Simple, natural solutions that work."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Paragraph Text",
      "default": "<p>At Meuse, we believe that nature has the power to soothe and calm the mind. That is why we focus on creating 100% natural products that are designed to fit seamlessly into your daily routines, and infuse them with moments of purposeful care.</p>"
    },
    {
      "type": "header",
      "content": "Desktop Sizing"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size (px)",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body Font Size (px)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "header",
      "content": "Mobile Sizing"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Mobile Font Size (px)",
      "min": 16,
      "max": 36,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Body Mobile Font Size (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Meuse Text-Image Split"
    }
  ]
}
{% endschema %}