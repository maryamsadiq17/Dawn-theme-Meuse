{% comment %}
  ============================================================
  MEUSE — ASYMMETRICAL TEXT & IMAGE SPLIT (THEME BREAKOUT)
  File: sections/meuse-text-image-split.liquid
  ============================================================
{% endcomment %}

{%- style -%}
  /* ── Ultra-High Specificity Breakout ─────────────────── */
  /* This completely overrides Dawn theme max-width restrictions */
  div.shopify-section.meuse-split-section,
  .shopify-section.meuse-split-section,
  #shopify-section-{{ section.id }} {
    width: 100vw !important;
    max-width: 100vw !important;
    min-width: 100vw !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: calc(-50vw + 50%) !important;
    margin-right: calc(-50vw + 50%) !important;
    position: relative;
    left: 0 !important;
    right: 0 !important;
    display: block !important;
  }

  /* ── Root Container Framework ────────────────────────── */
  #mtis-{{ section.id }} {
    position: relative;
    width: 100vw !important;
    max-width: 100vw !important;
    height: {{ section.settings.section_height_desktop }}px;
    background-color: {{ section.settings.section_bg }};
    overflow: hidden;
    margin: 0 !important;
    padding: 0 !important;
    box-sizing: border-box !important;
  }

  /* ── Asymmetrical Grid Layout ────────────────────────── */
  /* Left column (Image): 42vw | Right column (Text): 58vw */
  #mtis-{{ section.id }} .mtis__grid {
    display: grid !important;
    grid-template-columns: 42vw 58vw !important; 
    width: 100vw !important;
    max-width: 100vw !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    position: relative;
    z-index: 2;
  }

  /* ── Left Side Frame (Flush Left Wall) ───────────────── */
  #mtis-{{ section.id }} .mtis__image-column {
    width: 100% !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  #mtis-{{ section.id }} .mtis__image-column img,
  #mtis-{{ section.id }} .mtis__image-column .mtis__placeholder {
    width: 100% !important;
    height: 100% !important;
    display: block !important;
    object-fit: cover !important;
  }

  #mtis-{{ section.id }} .mtis__placeholder {
    background-color: #e2e2e2;
  }

  /* ── Right Side Frame (Flush Right Wall) ─────────────── */
  #mtis-{{ section.id }} .mtis__text-column {
    background-color: {{ section.settings.block_bg }} !important;
    height: 100% !important;
    display: flex !important;
    align-items: flex-start !important; /* Forces text content straight to the top */
    justify-content: flex-start !important;
    padding: 120px 8% 60px 10% !important; /* Top elevation push */
    box-sizing: border-box !important;
  }

  #mtis-{{ section.id }} .mtis__content {
    max-width: 620px !important; /* Wide baseline matches Figma alignment exactly */
    width: 100% !important;
  }

  /* ── Typography Styling ──────────────────────────────── */
  #mtis-{{ section.id }} .mtis__heading {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: {{ section.settings.heading_size }}px !important;
    font-weight: 400 !important;
    line-height: 1.25 !important;
    color: {{ section.settings.heading_color }} !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    margin: 0 0 36px 0 !important;
  }

  #mtis-{{ section.id }} .mtis__text {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: {{ section.settings.text_size }}px !important;
    font-weight: 400 !important;
    line-height: 1.8 !important;
    color: {{ section.settings.text_color }} !important;
    letter-spacing: 0.02em !important;
    margin: 0 !important;
  }

  #mtis-{{ section.id }} .mtis__text p {
    margin: 0 0 22px 0 !important;
  }
  #mtis-{{ section.id }} .mtis__text p:last-child {
    margin: 0 !important;
  }

  /* ── Absolute Background Vector Layers ───────────────── */
  #mtis-{{ section.id }} .mtis__vector-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  #mtis-{{ section.id }} .mtis__vector {
    position: absolute;
    opacity: {{ section.settings.vector_opacity | divided_by: 100.0 }};
  }

  #mtis-{{ section.id }} .mtis__vector--top-right {
    top: 0;
    right: 0;
    width: 32vw;
    max-width: 480px;
  }

  #mtis-{{ section.id }} .mtis__vector--bottom-left {
    bottom: 0;
    left: 0;
    width: 25vw;
    max-width: 380px;
  }

  #mtis-{{ section.id }} .mtis__vector svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Mobile & Tablet Layout Adaptability ─────────────── */
  @media screen and (max-width: 989px) {
    div.shopify-section.meuse-split-section,
    .shopify-section.meuse-split-section,
    #shopify-section-{{ section.id }} {
      margin-left: 0 !important;
      margin-right: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    #mtis-{{ section.id }} {
      height: auto !important;
      width: 100% !important;
    }

    #mtis-{{ section.id }} .mtis__grid {
      grid-template-columns: 1fr !important;
      width: 100% !important;
      height: auto !important;
    }

    #mtis-{{ section.id }} .mtis__image-column {
      height: 480px !important;
    }

    #mtis-{{ section.id }} .mtis__text-column {
      padding: 60px 24px !important;
      align-items: center !important;
    }

    #mtis-{{ section.id }} .mtis__heading {
      font-size: {{ section.settings.heading_size_mobile }}px !important;
      margin-bottom: 24px !important;
      text-align: center !important;
    }

    #mtis-{{ section.id }} .mtis__text {
      font-size: {{ section.settings.text_size_mobile }}px !important;
    }
  }
{%- endstyle -%}

{{- 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&display=swap' | stylesheet_tag -}}

<div id="mtis-{{ section.id }}" class="meuse-text-image-split">
  
  <div class="mtis__vector-layer">
    <div class="mtis__vector mtis__vector--top-right">
      <svg viewBox="0 0 357 282" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M72.5 0C110.5 83.5 240.5 45.5 357 101M0 45C86.5 111.5 158.5 20.5 357 149M0 115C118.5 186.5 143.5 69.5 357 197.5M0 191.5C149.5 261 179.5 119.5 357 241M41 281.5C193.5 329.5 233.5 178 357 281.5" stroke="{{ section.settings.vector_color }}" stroke-width="0.7"/>
      </svg>
    </div>

    <div class="mtis__vector mtis__vector--bottom-left">
      <svg viewBox="0 0 294 227" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 0C46.5 36.5 83 91.5 59.5 137.5C36 183.5 -17.5 192.5 0 227M0 49C78.5 85.5 125.5 127 109 167C92.5 207 41.5 208.5 54 227M0 102C106 136.5 162.5 160 152 192C141.5 224 99.5 219.5 108.5 227M0 151.5C124 179.5 190.5 191 189 211C187.5 231 154.5 224.5 160.5 227M0 199.5C136 218 214 221.5 217.5 225C221 228.5 199.5 226.5 204.5 227" stroke="{{ section.settings.vector_color }}" stroke-width="0.7"/>
      </svg>
    </div>
  </div>

  <div class="mtis__grid">
    
    <div class="mtis__image-column">
      {%- if section.settings.image != blank -%}
        {%- capture sizes -%}42vw{%- endcapture -%}
        {{ section.settings.image | image_url: width: 1800 | image_tag:
          loading: 'lazy',
          sizes: sizes,
          widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
          alt: section.settings.heading
        }}
      {%- else -%}
        <div class="mtis__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
      {%- endif -%}
    </div>

    <div class="mtis__text-column">
      <div class="mtis__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="mtis__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="mtis__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Meuse Text-Image Split",
  "tag": "section",
  "class": "meuse-split-section",
  "settings": [
    {
      "type": "header",
      "content": "Media Content Asset"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image Source"
    },
    {
      "type": "header",
      "content": "Section Sizing Setup"
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "label": "Desktop Height (px)",
      "min": 600,
      "max": 1100,
      "step": 4,
      "default": 952
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background Canvas",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "block_bg",
      "label": "Text Block Background Color",
      "default": "#d2d7cb"
    },
    {
      "type": "header",
      "content": "Vector Artwork Properties"
    },
    {
      "type": "color",
      "id": "vector_color",
      "label": "Vector Path Stroke Color",
      "default": "#2a2a2a"
    },
    {
      "type": "range",
      "id": "vector_opacity",
      "label": "Vector Line Opacity (%)",
      "min": 5,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "header",
      "content": "Typography Copy Elements"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Content String",
      "default": "Simple, natural solutions that work."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Copy Paragraph Text",
      "default": "<p>At Meuse, we believe that nature has the power to soothe and calm the mind. That is why we focus on creating 100% natural products that are designed to fit seamlessly into your daily routines, and infuse them with moments of purposeful care.</p>"
    },
    {
      "type": "header",
      "content": "Desktop Text Configurations"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size (px)",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body Font Size (px)",
      "min": 14,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "header",
      "content": "Mobile Text Configurations"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Mobile Font Size (px)",
      "min": 16,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Body Mobile Font Size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Meuse Text-Image Split"
    }
  ]
}
{% endschema %}