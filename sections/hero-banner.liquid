<section
  id="hero-{{ section.id }}"
  class="hero-banner"
  style="
    --overlay: {{ section.settings.overlay_color }};
    --hero-h: {{ section.settings.height }}px;
  "
>
    {%- if section.settings.bg_image != blank -%}
  <img
    src="{{ section.settings.bg_image
      | image_url: width: 1920 }}"
    alt="{{ section.settings.bg_image.alt }}"
    class="hero-banner__bg"
    loading="eager"
  >
{%- endif -%}

<div class="hero-banner__content">
  <h1 class="hero-banner__heading">
    {{ section.settings.heading }}
  </h1>
  {%- if section.settings.btn_text != blank -%}
    <a href="{{ section.settings.btn_link }}"
       class="hero-banner__btn">
      {{ section.settings.btn_text }}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Visit our store</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#00000055"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height",
      "min": 300, "max": 800,
      "step": 20, "default": 500
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}